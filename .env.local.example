# Supabase - get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
JWT_SECRET=generate-with-openssl-rand-base64-32

# Paystack proxy skill variables
# PAYSTACK_FN_BASE must be a full URL, for example https://paysync.leadsync.co.za/functions/v1
PAYSTACK_FN_BASE=https://paysync.leadsync.co.za/functions/v1
PAYSTACK_CREDENTIAL_ID=your-credential-id
PAYSTACK_CREDENTIAL_KEY=your-credential-key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx
NEXT_PUBLIC_SITE_URL=https://your-domain.com
